# BasicAccountFlow

main: kit: flow: BasicAccountFlow:
{
  entity: "account",
  kind: "basic",
  name: "BasicAccountFlow",
  step: [
    {
      op: "list",
      valid: [
        {
          apply: "ItemExists",
          def: {
            ref: "account_ref01"
          }
        }
      ]
    }
  ],
  "key$": "BasicAccountFlow"
}